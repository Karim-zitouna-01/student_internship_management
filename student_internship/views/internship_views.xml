<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Internship Tree View -->
    <record id="view_student_internship_internship_tree" model="ir.ui.view">
        <field name="name">student.internship.internship.tree</field>
        <field name="model">student.internship.internship</field>
        <field name="arch" type="xml">
            <tree>
                <field name="student_id"/>
                <field name="company_id"/>
                <field name="supervisor_id"/>
                <field name="start_date"/>
                <field name="end_date"/>
                <field name="duration"/>
                <field name="status" widget="badge" 
                       decoration-info="status == 'draft'"
                       decoration-warning="status == 'submitted'"
                       decoration-success="status == 'approved'"
                       decoration-muted="status == 'finished'"/>
                <field name="evaluation_score"/>
            </tree>
        </field>
    </record>

    <!-- Internship Form View -->
    <record id="view_student_internship_internship_form" model="ir.ui.view">
        <field name="name">student.internship.internship.form</field>
        <field name="model">student.internship.internship</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <!-- Status Bar Widget -->
                    <field name="status" widget="statusbar" 
                           statusbar_visible="draft,submitted,approved,finished"/>
                    
                    <!-- Workflow Buttons -->
                    <button name="action_submit" 
                            string="Submit" 
                            type="object" 
                            class="oe_highlight"
                            invisible="status != 'draft'"/>
                    
                    <button name="action_approve" 
                            string="Approve" 
                            type="object" 
                            class="oe_highlight"
                            invisible="status != 'submitted'"/>
                    
                    <button name="action_finish" 
                            string="Finish" 
                            type="object" 
                            class="oe_highlight"
                            invisible="status != 'approved'"/>
                </header>
                
                <sheet>
                    <group>
                        <group string="Assignment Information">
                            <field name="student_id"/>
                            <field name="company_id"/>
                            <field name="supervisor_id"/>
                        </group>
                        <group string="Duration">
                            <field name="start_date"/>
                            <field name="end_date"/>
                            <field name="duration"/>
                        </group>
                    </group>
                    
                    <group string="Evaluation">
                        <group>
                            <field name="evaluation_score"/>
                        </group>
                        <group>
                            <field name="evaluation_comment" nolabel="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Internship Action -->
    <record id="action_student_internship_internship" model="ir.actions.act_window">
        <field name="name">Internships</field>
        <field name="res_model">student.internship.internship</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first internship
            </p>
            <p>
                Click the create button to register a new internship assignment.
            </p>
        </field>
    </record>
</odoo>
